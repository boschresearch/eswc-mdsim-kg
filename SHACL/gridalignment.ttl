@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix md: <http://example.bosch.com/mdsim/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

md:PartInCenterGridShape a sh:NodeShape ;
  sh:targetClass md:Part ;

  sh:property [
    sh:path md:hasXCoordinate ;
    sh:minCount 1 ;
    sh:minInclusive -2 ;
    sh:maxInclusive  2 ;
    sh:severity sh:Warning ;
    sh:message "Part x-position outside manufacturing 'center' grid (expected [-2..2])." ;
  ] ;

  sh:property [
    sh:path md:hasYCoordinate ;
    sh:minCount 1 ;
    sh:minInclusive -2 ;
    sh:maxInclusive  2 ;
    sh:severity sh:Warning ;
    sh:message "Part y-position outside manufacturing 'center' grid (expected [-2..2])." ;
  ] .

md:PartOutOfCenterGridShape
  a sh:NodeShape ;
  sh:not md:PartInCenterGridShape .

md:WaferGridAlignmentWarningShape
  a sh:NodeShape ;
  sh:targetClass md:Wafer ;

  sh:property [
    sh:path [ sh:inversePath md:fabricatedOnWafer ] ;
    sh:qualifiedValueShape md:PartOutOfCenterGridShape ;
    sh:qualifiedMaxCount 0 ;
    sh:severity sh:Warning ;
    sh:message "Wafer has at least one part outside the manufacturing 'center' grid (expected x,y in [-2..2])." ;
  ] .
