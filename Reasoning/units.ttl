@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix md: <http://example.bosch.com/mdsim/> .

md:ParameterUnitShape a sh:NodeShape ;
  sh:targetClass md:Parameter ;
  sh:property [
    sh:path qudt:unit ;
    sh:nodeKind sh:IRI ;
    sh:class qudt:Unit ;
    sh:severity sh:Violation ;
    sh:message "Value must be a valid qudt unit (http://qudt.org/3.1.10/vocab/unit)";
  ] .